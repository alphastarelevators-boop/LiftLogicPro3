<Window x:Class="LiftLogicPro.Views.Login.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
        xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
        Title="تسجيل الدخول"
        Height="450" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        FlowDirection="RightToLeft">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Logo -->
        <TextBlock Grid.Row="0" 
                   Text="🔐" 
                   FontSize="60" 
                   HorizontalAlignment="Center"/>

        <TextBlock Grid.Row="0" 
                   Text="تسجيل الدخول" 
                   FontSize="20" 
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,70,0,0"/>

        <!-- User Input (رقم الموظف أو اسم المستخدم) -->
        <dxe:TextEdit Grid.Row="2" 
                      NullText="رقم الموظف أو اسم المستخدم"
                      Height="40" 
                      Margin="0,8"
                         CornerRadius="10"
                      
                      Text="{Binding UserInput, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Password -->
        <dxe:PasswordBoxEdit Grid.Row="3" 
                             NullText="كلمة المرور"
                             Height="40" 
                             Margin="0,8"
                             CornerRadius="10"
                             Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"/>
        

        <!-- Status -->
        <TextBlock Grid.Row="4" 
                   Text="{Binding StatusMessage}" 
                   Foreground="Red"
                   HorizontalAlignment="Center"
                   Margin="0,10"
                   TextWrapping="Wrap"/>

        <!-- Login Button -->
        <dx:SimpleButton Grid.Row="5"
                         Content="دخول"
                         Width="200" 
                         Height="45"
                          CornerRadius="10"
                         Command="{Binding LoginCommand}"/>
    </Grid>
</Window>