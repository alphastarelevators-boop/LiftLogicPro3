<Window x:Class="LiftLogicPro.Views.Connection.ConnectionView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
        xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
        Title="إعدادات الاتصال"
        Height="500" Width="550"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        FlowDirection="RightToLeft">

    <Grid Margin="30">
        <TextBlock Text="ليفت لوجيك برو" 
                   FontSize="24" 
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <StackPanel VerticalAlignment="Center">
            <dxe:TextEdit NullText="اسم السيرفر" 
                          Height="40" Margin="0,8"
                          Text="{Binding ServerName, UpdateSourceTrigger=PropertyChanged}"/>

            <dxe:TextEdit NullText="قاعدة البيانات" 
                          Height="40" Margin="0,8"
                          Text="{Binding DatabaseName, UpdateSourceTrigger=PropertyChanged}"/>

            <dxe:TextEdit NullText="اسم المستخدم" 
                          Height="40" Margin="0,8"
                          Text="{Binding UserId, UpdateSourceTrigger=PropertyChanged}"/>

            <dxe:PasswordBoxEdit NullText="كلمة المرور" 
                                 Height="40" Margin="0,8"
                                 Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Text="{Binding StatusMessage}" 
                       Foreground="Green"
                       HorizontalAlignment="Center"
                       Margin="0,10"
                       TextWrapping="Wrap"/>

            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Center" 
                        Margin="0,20">

                <dx:SimpleButton Content="اختبار الاتصال" 
                                 Width="140" Height="45" Margin="8"
                                 Command="{Binding TestConnectionCommand}"/>

                <dx:SimpleButton Content="حفظ الاتصال" 
                                 Width="140" Height="45" Margin="8"
                                 Command="{Binding SaveConnectionCommand}"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>